<Window x:Class="PdfPrintUtility.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Preview" Height="750" Width="620"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Icon="/icon.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#EFEFEF" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,6">
                <Button x:Name="PrevBtn" Content="◀  Prev" Padding="12,4" Margin="0,0,6,0"
                        Click="PrevBtn_Click" IsEnabled="False"/>
                <TextBlock x:Name="PageLabel" Text="Page 1 of 1"
                           VerticalAlignment="Center" Margin="8,0" FontSize="13" FontWeight="SemiBold"/>
                <Button x:Name="NextBtn" Content="Next  ▶" Padding="12,4"
                        Click="NextBtn_Click" IsEnabled="False"/>
                <Separator Width="1" Margin="14,2" Background="#CCCCCC"/>
                <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                <ComboBox x:Name="ZoomComboBox" Width="110" Height="26" VerticalContentAlignment="Center"
                          SelectionChanged="ZoomComboBox_SelectionChanged">
                    <ComboBoxItem Content="Fit Width" Tag="fit_width" IsSelected="True"/>
                    <ComboBoxItem Content="Fit Page"  Tag="fit_page"/>
                    <ComboBoxItem Content="50%"       Tag="0.5"/>
                    <ComboBoxItem Content="75%"       Tag="0.75"/>
                    <ComboBoxItem Content="100%"      Tag="1.0"/>
                    <ComboBoxItem Content="125%"      Tag="1.25"/>
                    <ComboBoxItem Content="150%"      Tag="1.5"/>
                    <ComboBoxItem Content="200%"      Tag="2.0"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Preview area -->
        <ScrollViewer Grid.Row="1" x:Name="PreviewScrollViewer"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="#606060"
                      SizeChanged="PreviewScrollViewer_SizeChanged">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
                <!-- Drop shadow -->
                <Border CornerRadius="2" Margin="4,4,0,0" Background="#55000000"/>
                <!-- Page image -->
                <Border x:Name="PageBorder" Background="White" CornerRadius="2">
                    <Image x:Name="PreviewImage"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="None"/>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#EFEFEF" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <TextBlock x:Name="FileNameLabel" Text="" Margin="10,5"
                       FontSize="11" Foreground="#555555" TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
