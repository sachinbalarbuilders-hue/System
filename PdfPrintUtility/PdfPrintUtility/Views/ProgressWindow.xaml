<Window x:Class="PdfPrintUtility.Views.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Printing PDFs" Height="150" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True" WindowStyle="ToolWindow" Icon="/icon.png">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusTextBlock" Text="Preparing to print..." FontWeight="Bold" Margin="0,0,0,10"/>
        <ProgressBar x:Name="PrintProgressBar" Grid.Row="1" Height="20" Margin="0,0,0,10"/>
        <TextBlock x:Name="DetailsTextBlock" Grid.Row="2" Text="" Foreground="Gray" FontSize="11" TextTrimming="CharacterEllipsis"/>
    </Grid>
</Window>
