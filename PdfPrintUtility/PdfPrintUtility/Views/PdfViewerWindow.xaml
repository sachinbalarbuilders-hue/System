<Window x:Class="PdfPrintUtility.Views.PdfViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Native PDF Viewer" Height="800" Width="900"
        WindowStartupLocation="CenterOwner" Icon="/icon.png">
    <Grid>
        <TabControl x:Name="PdfTabControl" Background="Transparent" BorderThickness="0">
            <!-- Custom template for tab headers to include a close button -->
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding HeaderText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="✕" Width="16" Height="16" Background="Transparent" BorderThickness="0" 
                                            Foreground="Gray" FontSize="10" FontWeight="Bold" Cursor="Hand"
                                            Click="CloseTab_Click" Tag="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Padding" Value="10,5"/>
                </Style>
            </TabControl.Resources>
        </TabControl>
    </Grid>
</Window>
