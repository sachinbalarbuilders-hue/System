<Window x:Class="PdfPrintUtility.Views.ScannerWorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scanner Workspace" Height="700" Width="900"
        WindowStartupLocation="CenterOwner" Icon="/icon.png">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button x:Name="ScanMoreBtn" Content="Scan Another Page" Height="40" Margin="0,0,0,10" 
                    Background="#17A2B8" Foreground="White" FontWeight="Bold" Click="ScanMoreBtn_Click" />

            <ListBox x:Name="PagesListBox" Grid.Row="1" SelectionChanged="PagesListBox_SelectionChanged" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <Image Source="{Binding ImagePath}" Height="150" Stretch="Uniform" />
                            <TextBlock Text="{Binding PageName}" HorizontalAlignment="Center" Margin="0,5,0,0" />
                            <Button Content="Remove" Tag="{Binding}" Click="RemovePageBtn_Click" Margin="0,5,0,0" Padding="5,2" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <!-- Tile Copies -->
                <Border Background="#F0F8FF" BorderBrush="#007BFF" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Tile Copies on A4" FontWeight="Bold" Foreground="#007BFF" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Copies:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox x:Name="TileCopiesBox" Width="50" Text="8" VerticalContentAlignment="Center" Padding="4,2"/>
                        </StackPanel>
                        <Button x:Name="TileCopiesBtn" Content="Generate Tile Sheet" Height="30" 
                                Background="#007BFF" Foreground="White" FontWeight="Bold"
                                Click="TileCopiesBtn_Click" IsEnabled="False"/>
                    </StackPanel>
                </Border>
                <Button x:Name="SavePdfBtn" Content="Save to PDF" Height="35" Margin="0,0,0,5" Click="SavePdfBtn_Click" />
                <Button x:Name="SaveImgBtn" Content="Save as Images" Height="35" Margin="0,0,0,5" Click="SaveImgBtn_Click" />
                <Button x:Name="AddToPrintBtn" Content="Add to Print Job" Height="40" Margin="0,5,0,0" 
                        Background="#28A745" Foreground="White" FontWeight="Bold" Click="AddToPrintBtn_Click" />
            </StackPanel>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="RotateBtn" Content="Rotate 90°" Height="30" Width="80" Margin="0,0,10,0" Click="RotateBtn_Click" IsEnabled="False" />
                <Button x:Name="CropBtn" Content="Crop Selection" Height="30" Width="120" Margin="0,0,10,0" Click="CropBtn_Click" IsEnabled="False" />
                <Button x:Name="AutoCropBtn" Content="Auto Crop" Height="30" Width="90" Margin="0,0,15,0" Click="AutoCropBtn_Click" IsEnabled="False" Background="#007BFF" Foreground="White" FontWeight="Bold" />
                <Separator Width="1" Background="Gray" Margin="0,2,10,2"/>
                <Button x:Name="ZoomOutBtn" Content="🔍−" Height="30" Width="38" Margin="0,0,4,0" Click="ZoomOutBtn_Click" FontSize="14" ToolTip="Zoom Out (Ctrl+Scroll)" />
                <TextBlock x:Name="ZoomLabel" Text="100%" VerticalAlignment="Center" Width="40" TextAlignment="Center" FontWeight="Bold" />
                <Button x:Name="ZoomInBtn" Content="🔍+" Height="30" Width="38" Margin="4,0,8,0" Click="ZoomInBtn_Click" FontSize="14" ToolTip="Zoom In (Ctrl+Scroll)" />
                <Button x:Name="ZoomFitBtn" Content="Fit" Height="30" Width="38" Click="ZoomFitBtn_Click" ToolTip="Fit to window" />
                <TextBlock Text="  Drag on image to draw crop box." VerticalAlignment="Center" Foreground="Gray" FontSize="11" />
            </StackPanel>

            <Border Grid.Row="1" Background="#E0E0E0" BorderBrush="Gray" BorderThickness="1" ClipToBounds="True">
                <ScrollViewer x:Name="PreviewScroller" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="PreviewScroller_MouseWheel">
                    <Grid x:Name="PreviewGrid">
                        <Grid.LayoutTransform>
                            <ScaleTransform x:Name="PreviewZoom" ScaleX="1" ScaleY="1"/>
                        </Grid.LayoutTransform>
                        <Image x:Name="PreviewImage" Stretch="None" 
                               MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                               MouseMove="PreviewImage_MouseMove"
                               MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp" />
                        <Canvas x:Name="CropCanvas">
                            <Rectangle x:Name="CropRectangle" Stroke="Red" StrokeThickness="2" StrokeDashArray="4 4" Visibility="Collapsed" />
                        </Canvas>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
