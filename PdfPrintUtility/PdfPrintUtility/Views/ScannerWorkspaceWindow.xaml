<Window x:Class="PdfPrintUtility.Views.ScannerWorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scanner Workspace" Height="750" Width="1000" MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterOwner" Icon="/icon.png"
        Background="#F4F5F7">
    <!-- UI REFACTOR: Reorganized layout with Top Toolbar, Main Content, Footer Actions, and Status Bar -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Top Toolbar -->
            <RowDefinition Height="*" />    <!-- Main Content -->
            <RowDefinition Height="Auto" /> <!-- Footer Actions -->
            <RowDefinition Height="Auto" /> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- UI REFACTOR: Top Toolbar for tools with primary/secondary styles and tooltips -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal">
                <!-- Scan Settings -->
                <TextBlock Text="DPI:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                <ComboBox x:Name="DpiComboBox" Width="80" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0" ToolTip="Scan resolution — 300 DPI suits most documents">
                    <ComboBoxItem Content="150 DPI" Tag="150"/>
                    <ComboBoxItem Content="200 DPI" Tag="200"/>
                    <ComboBoxItem Content="300 DPI" Tag="300" IsSelected="True"/>
                    <ComboBoxItem Content="600 DPI" Tag="600"/>
                </ComboBox>
                <TextBlock Text="Mode:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                <ComboBox x:Name="ColourModeComboBox" Width="105" Height="30" VerticalContentAlignment="Center" Margin="0,0,12,0" ToolTip="Colour mode — use Greyscale or B&amp;W for text documents">
                    <ComboBoxItem Content="Colour" Tag="4" IsSelected="True"/>
                    <ComboBoxItem Content="Greyscale" Tag="2"/>
                    <ComboBoxItem Content="Black &amp; White" Tag="1"/>
                </ComboBox>
                <Button x:Name="ScanMoreBtn" Content="Scan Document" Style="{StaticResource PrimaryBtnStyle}" Click="ScanMoreBtn_Click" ToolTip="Scan a new document from the scanner" />
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <Button x:Name="RotateBtn" Content="Rotate 90°" Style="{StaticResource SecondaryBtnStyle}" Click="RotateBtn_Click" IsEnabled="False" ToolTip="Rotate the image 90 degrees clockwise" />
                <Button x:Name="AutoCropBtn" Content="Auto Crop" Style="{StaticResource SecondaryBtnStyle}" Click="AutoCropBtn_Click" IsEnabled="False" ToolTip="Automatically detect and crop borders" />
                <Button x:Name="CropBtn" Content="Crop Selection" Style="{StaticResource SecondaryBtnStyle}" Click="CropBtn_Click" IsEnabled="False" ToolTip="Crop to the manually drawn red box" />
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <Button x:Name="ZoomOutBtn" Content="🔍−" Style="{StaticResource SecondaryBtnStyle}" Click="ZoomOutBtn_Click" ToolTip="Zoom Out (Ctrl+Scroll)" MinWidth="40" Padding="5" />
                <TextBlock x:Name="ZoomLabel" Text="100%" VerticalAlignment="Center" Width="45" TextAlignment="Center" FontWeight="Bold" Margin="4,0" />
                <Button x:Name="ZoomInBtn" Content="🔍+" Style="{StaticResource SecondaryBtnStyle}" Click="ZoomInBtn_Click" ToolTip="Zoom In (Ctrl+Scroll)" MinWidth="40" Padding="5" />
                <Button x:Name="ZoomFitBtn" Content="Fit" Style="{StaticResource SecondaryBtnStyle}" Click="ZoomFitBtn_Click" ToolTip="Fit to window" MinWidth="40" Padding="5" />
                <TextBlock Text="Drag on image to draw crop box." VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Gray" />
            </StackPanel>
        </Border>

        <!-- UI REFACTOR: Main Content Area -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <GroupBox Grid.Column="0" Header="Scanned Pages" Padding="5" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
                <ListBox x:Name="PagesListBox" SelectionChanged="PagesListBox_SelectionChanged" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <Border Background="#F0F0F0" Padding="5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                                    <Image Source="{Binding ImagePath}" Height="130" Stretch="Uniform" />
                                </Border>
                                <TextBlock Text="{Binding PageName}" HorizontalAlignment="Center" Margin="0,5,0,0" FontWeight="SemiBold" />
                                <Button Content="Remove" Tag="{Binding}" Style="{StaticResource DestructiveBtnStyle}" Click="RemovePageBtn_Click" Margin="0,5,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" Background="#DEE2E6" />

            <!-- Preview Area -->
            <Border Grid.Column="2" Background="#E9ECEF" BorderBrush="#DEE2E6" BorderThickness="1" ClipToBounds="True">
                <ScrollViewer x:Name="PreviewScroller" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="PreviewScroller_MouseWheel">
                    <Grid x:Name="PreviewGrid" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.LayoutTransform>
                            <ScaleTransform x:Name="PreviewZoom" ScaleX="1" ScaleY="1"/>
                        </Grid.LayoutTransform>
                        <Image x:Name="PreviewImage" Stretch="None" 
                               MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                               MouseMove="PreviewImage_MouseMove"
                               MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp" />
                        <Canvas x:Name="CropCanvas">
                            <Rectangle x:Name="CropRectangle" Stroke="Red" StrokeThickness="2" StrokeDashArray="4 4" Visibility="Collapsed" />
                        </Canvas>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- UI REFACTOR: Footer Actions -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#DEE2E6" BorderThickness="0,1,0,0" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Tile Generation -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Number of Copies per Sheet:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBox x:Name="TileCopiesBox" Width="60" Text="8" VerticalContentAlignment="Center" Margin="0,0,10,0" ToolTip="Number of copies" Height="30" />
                    <Button x:Name="TileCopiesBtn" Content="Generate Tile Sheet" Style="{StaticResource PrimaryBtnStyle}" 
                            Click="TileCopiesBtn_Click" IsEnabled="False" ToolTip="Create an A4 sheet tiled with this image" />
                </StackPanel>

                <!-- Export/Save Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="SaveImgBtn" Content="Save as Images" Style="{StaticResource SecondaryBtnStyle}" Click="SaveImgBtn_Click" ToolTip="Export pages as individual JPEG images" />
                    <Button x:Name="SavePdfBtn" Content="Save to PDF" Style="{StaticResource SecondaryBtnStyle}" Click="SavePdfBtn_Click" ToolTip="Export all pages as a PDF document" />
                    <Button x:Name="AddToPrintBtn" Content="Add to Print Job" Style="{StaticResource PrimaryBtnStyle}" Background="#10B981" Click="AddToPrintBtn_Click" ToolTip="Return these pages to the main print queue" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- UI REFACTOR: Status Strip -->
        <StatusBar Grid.Row="3" Background="#E9ECEF" Padding="10,2">
            <StatusBarItem>
                <TextBlock x:Name="StatusLabel" Text="Ready" />
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
            <StatusBarItem>
                <TextBlock x:Name="ImageDimensionsLabel" Text="Dimensions: N/A" />
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
            <StatusBarItem>
                <TextBlock x:Name="FileSizeLabel" Text="File Size: N/A" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
