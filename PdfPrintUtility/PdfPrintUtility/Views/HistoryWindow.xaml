<Window x:Class="PdfPrintUtility.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print History" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" Icon="/icon.png">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Right">
            <Button x:Name="RefreshBtn" Content="Refresh" Padding="15,5" Margin="0,0,10,0" Click="RefreshBtn_Click"/>
            <Button x:Name="ClearBtn" Content="Clear History" Padding="15,5" Click="ClearBtn_Click"/>
        </StackPanel>

        <DataGrid x:Name="HistoryDataGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" HeadersVisibility="Column" />
    </Grid>
</Window>
