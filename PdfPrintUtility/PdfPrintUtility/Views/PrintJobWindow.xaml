<Window x:Class="PdfPrintUtility.Views.PrintJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Print Job" MinHeight="750" MinWidth="1100"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        AllowDrop="True" Drop="Window_Drop" Icon="/icon.png"
        Background="#F4F5F7">
    <!-- UI REFACTOR: Reorganized PrintJobWindow into 40/60 split with clearly defined Section GroupBoxes and Status Bar -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" MinWidth="450"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="6*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════ LEFT: Settings ═══════════════════════════════════ -->
            <Grid Grid.Column="0" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- Section A: Input -->
                    <RowDefinition Height="Auto"/> <!-- Section C: Print Settings -->
                    <RowDefinition Height="Auto"/> <!-- Section D: Actions -->
                </Grid.RowDefinitions>

                <!-- SECTION A: INPUT SOURCE -->
                <GroupBox Grid.Row="0" Margin="0,0,0,12" Padding="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
                    <GroupBox.Header>
                        <TextBlock Text="Section A: Input Source &amp; Profiles" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Profiles -->
                        <Grid Grid.Row="0" Margin="0,5,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Profile:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="ProfileComboBox" Grid.Column="1" Height="28" SelectionChanged="ProfileComboBox_SelectionChanged" IsEditable="True"/>
                            <Button x:Name="SaveProfileBtn" Grid.Column="2" Content="Save" Style="{StaticResource SecondaryBtnStyle}" Click="SaveProfileBtn_Click" Margin="8,0,0,0"/>
                            <Button x:Name="DeleteProfileBtn" Grid.Column="3" Content="Delete" Style="{StaticResource DestructiveBtnStyle}" Click="DeleteProfileBtn_Click" Margin="5,0,0,0"/>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="Files to Print (Drag &amp; Drop to add)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ListBox x:Name="FilesListBox" Grid.Row="1" Margin="0,25,0,0" SelectionChanged="FilesListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DisplayText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}" VerticalAlignment="Center">
                                            <TextBlock.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Open in Viewer" Click="ViewPdf_Click" Tag="{Binding}"/>
                                                    <MenuItem Header="Rotate 90° CW" Click="RotateItem_Click" Tag="{Binding}"/>
                                                    <MenuItem Header="Move Up" Click="MoveUp_Click" Tag="{Binding}"/>
                                                    <MenuItem Header="Move Down" Click="MoveDown_Click" Tag="{Binding}"/>
                                                    <MenuItem Header="Remove" Click="RemoveFile_Click" Tag="{Binding}"/>
                                                </ContextMenu>
                                            </TextBlock.ContextMenu>
                                        </TextBlock>
                                        <Button Grid.Column="1" Content="Remove" Style="{StaticResource DestructiveBtnStyle}" Padding="8,2" MinHeight="24" Click="RemoveFile_Click" Tag="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>

                <!-- SECTION C: TILE / PRINT SETTINGS -->
                <GroupBox Grid.Row="1" Margin="0,0,0,12" Padding="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
                    <GroupBox.Header>
                        <TextBlock Text="Section C: Print Settings" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                    </GroupBox.Header>
                    <StackPanel Margin="0,5,0,0">
                        <!-- Copies -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Number of Copies per Sheet:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="CopiesTextBox" Width="80" Height="28" Text="1" VerticalContentAlignment="Center" FontSize="14" FontWeight="Bold" TextAlignment="Center"/>
                        </StackPanel>

                        <!-- Printer / Tray -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Printer:" Margin="0,0,0,4"/>
                                <ComboBox x:Name="PrinterComboBox" Height="28" SelectionChanged="PrinterComboBox_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Paper Tray:" Margin="0,0,0,4"/>
                                <ComboBox x:Name="PaperTrayComboBox" Height="28"/>
                            </StackPanel>
                        </Grid>

                        <!-- Paper / Fit / Color -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Paper Size:" Margin="0,0,0,4"/>
                                <ComboBox x:Name="PaperSizeComboBox" Height="28" SelectionChanged="PreviewSettings_Changed">
                                    <ComboBoxItem Content="Auto (Match Document)" IsSelected="True"/>
                                    <ComboBoxItem Content="A3"/>
                                    <ComboBoxItem Content="A4"/>
                                    <ComboBoxItem Content="Letter"/>
                                    <ComboBoxItem Content="Legal"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Text="Fit Mode:" Margin="0,0,0,4"/>
                                <ComboBox x:Name="FitModeComboBox" Height="28" SelectionChanged="PreviewSettings_Changed">
                                    <ComboBoxItem Content="Fit to Page" Tag="FitToPage" IsSelected="True"/>
                                    <ComboBoxItem Content="Shrink to Fit" Tag="ShrinkToFit"/>
                                    <ComboBoxItem Content="Actual Size" Tag="ActualSize"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="Color Mode:" Margin="0,0,0,4"/>
                                <ComboBox x:Name="ColorComboBox" Height="28" SelectionChanged="PreviewSettings_Changed">
                                    <ComboBoxItem Content="Color" IsSelected="True"/>
                                    <ComboBoxItem Content="Grayscale"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Orientation / Watermark / Range -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Orientation:" Margin="0,0,0,4"/>
                                <ComboBox x:Name="OrientationComboBox" Height="28" SelectionChanged="PreviewSettings_Changed">
                                    <ComboBoxItem Content="Auto" IsSelected="True"/>
                                    <ComboBoxItem Content="Portrait"/>
                                    <ComboBoxItem Content="Landscape"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Text="Watermark:" Margin="0,0,0,4"/>
                                <TextBox x:Name="WatermarkTextBox" Height="28" VerticalContentAlignment="Center" TextChanged="WatermarkTextBox_TextChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="Pages to Print (1-5, 8):" Margin="0,0,0,4"/>
                                <TextBox x:Name="PageRangeTextBox" Height="28" VerticalContentAlignment="Center" TextChanged="PageRangeTextBox_TextChanged"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="DuplexCheckBox" Content="Double-Sided (Duplex)" Margin="0,0,20,0"/>
                            <CheckBox x:Name="CollateCheckBox" Content="Collate Copies" IsChecked="True"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- SECTION D: ACTIONS -->
                <GroupBox Grid.Row="2" Padding="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
                    <GroupBox.Header>
                        <TextBlock Text="Section D: Actions" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                    </GroupBox.Header>
                    <WrapPanel Margin="0,5,0,0" HorizontalAlignment="Stretch">
                        <Button x:Name="ScanBtn" Content="Scan Document" Style="{StaticResource PrimaryBtnStyle}" Background="#10B981" Click="ScanBtn_Click"/>
                        <Button x:Name="MergeBtn" Content="Merge PDFs" Style="{StaticResource SecondaryBtnStyle}" Click="MergeBtn_Click"/>
                        <Button x:Name="HistoryBtn" Content="History" Style="{StaticResource SecondaryBtnStyle}" Click="HistoryBtn_Click"/>
                        <Button x:Name="CancelBtn" Content="Cancel" Style="{StaticResource DestructiveBtnStyle}" Click="CancelButton_Click" Margin="20,6,6,6"/>
                        <Button x:Name="PrintBtn" Content="Print" Style="{StaticResource PrimaryBtnStyle}" MinWidth="120" FontSize="14" Click="PrintButton_Click"/>
                    </WrapPanel>
                </GroupBox>
            </Grid>

            <!-- ═══════════════════════════════════ SPLITTER ═══════════════════════════════════ -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#DEE2E6" Cursor="SizeWE"/>

            <!-- ═══════════════════════════════════ RIGHT: Inline Preview (60%) ═══════════════════════════════════ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Toolbar -->
                    <RowDefinition Height="*"/>    <!-- Image -->
                    <RowDefinition Height="Auto"/> <!-- File label -->
                </Grid.RowDefinitions>

                <!-- Preview toolbar -->
                <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="8,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="InlinePrevBtn" Content="◀ Prev" Style="{StaticResource SecondaryBtnStyle}" MinWidth="60" Padding="5" Click="InlinePrevBtn_Click" IsEnabled="False"/>
                        <TextBlock x:Name="InlinePageLabel" Text="Select a file to preview" VerticalAlignment="Center" Margin="15,0" FontWeight="SemiBold"/>
                        <Button x:Name="InlineNextBtn" Content="Next ▶" Style="{StaticResource SecondaryBtnStyle}" MinWidth="60" Padding="5" Click="InlineNextBtn_Click" IsEnabled="False"/>
                        <Button x:Name="PopOutBtn" Content="⤢ Open Viewer" Style="{StaticResource SecondaryBtnStyle}" Margin="20,0,0,0" Padding="10,5" Click="PopOutBtn_Click" IsEnabled="False"/>
                    </StackPanel>
                </Border>

                <!-- Preview image -->
                <Grid Grid.Row="1" Background="#525659">
                    <ScrollViewer x:Name="InlineScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" SizeChanged="InlineScrollViewer_SizeChanged">
                        <Border x:Name="InlinePageBorder" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.6"/>
                            </Border.Effect>
                            <Image x:Name="InlinePreviewImage" RenderOptions.BitmapScalingMode="HighQuality" Stretch="None"/>
                        </Border>
                    </ScrollViewer>
                    <TextBlock x:Name="PaperInfoLabel" Text="" Foreground="#E0E0E0" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0" IsHitTestVisible="False"/>
                </Grid>

                <!-- File name -->
                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#DEE2E6" BorderThickness="0,1,0,0" Padding="8,6">
                    <TextBlock x:Name="InlineFileLabel" Text="" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                </Border>
            </Grid>
        </Grid>

        <!-- UI REFACTOR: Status Strip -->
        <StatusBar Grid.Row="1" Background="#E9ECEF" Padding="10,2">
            <StatusBarItem>
                <TextBlock x:Name="StatusLabel" Text="Ready" />
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
            <StatusBarItem>
                <TextBlock x:Name="FileCountLabel" Text="Files: 0" />
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
            <StatusBarItem>
                <TextBlock x:Name="PreviewStatusLabel" Text="Preview: None" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
