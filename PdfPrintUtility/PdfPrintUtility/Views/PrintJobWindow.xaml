<Window x:Class="PdfPrintUtility.Views.PrintJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Print Job" MinHeight="700" MinWidth="960"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        AllowDrop="True" Drop="Window_Drop" Icon="/icon.png">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="520" MinWidth="480"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="200"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════ LEFT: Settings ═══════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Profiles -->
                <RowDefinition Height="*"/>    <!-- File List -->
                <RowDefinition Height="Auto"/> <!-- Printer / Tray / Copies -->
                <RowDefinition Height="Auto"/> <!-- Checkboxes -->
                <RowDefinition Height="Auto"/> <!-- Color / Orientation -->
                <RowDefinition Height="Auto"/> <!-- Paper Size / Fit / Watermark -->
                <RowDefinition Height="Auto"/> <!-- Page Range -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Profiles -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Profile:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="ProfileComboBox" Grid.Column="1" Height="25" SelectionChanged="ProfileComboBox_SelectionChanged" IsEditable="True"/>
                <Button x:Name="SaveProfileBtn" Grid.Column="2" Content="Save" Margin="8,0,0,0" Padding="10,0" Click="SaveProfileBtn_Click"/>
                <Button x:Name="DeleteProfileBtn" Grid.Column="3" Content="Delete" Margin="5,0,0,0" Padding="10,0" Click="DeleteProfileBtn_Click"/>
            </Grid>

            <GroupBox Grid.Row="1" Header="Files to Print (Drag &amp; Drop to add)" Margin="0,0,0,12" FontWeight="Bold">
                <ListBox x:Name="FilesListBox" Margin="5" FontWeight="Normal" SelectionChanged="FilesListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DisplayText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}" VerticalAlignment="Center">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Open in Viewer" Click="ViewPdf_Click" Tag="{Binding}"/>
                                            <MenuItem Header="Rotate 90° CW" Click="RotateItem_Click" Tag="{Binding}"/>
                                            <MenuItem Header="Move Up" Click="MoveUp_Click" Tag="{Binding}"/>
                                            <MenuItem Header="Move Down" Click="MoveDown_Click" Tag="{Binding}"/>
                                            <MenuItem Header="Remove" Click="RemoveFile_Click" Tag="{Binding}"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                                <Button Grid.Column="1" Content="Remove" Margin="8,0,0,0" Padding="5,2" Click="RemoveFile_Click" Tag="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Printer / Tray / Copies -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Printer:" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="PrinterComboBox" Height="25" SelectionChanged="PrinterComboBox_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Paper Tray:" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="PaperTrayComboBox" Height="25"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Copies:" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="CopiesTextBox" Height="25" Text="1" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Checkboxes -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                <CheckBox x:Name="DuplexCheckBox" Content="Double-Sided (Duplex)" Margin="0,0,20,0"/>
                <CheckBox x:Name="CollateCheckBox" Content="Collate Copies" IsChecked="True"/>
            </StackPanel>

            <!-- Color / Orientation -->
            <Grid Grid.Row="4" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Color Mode:" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ColorComboBox" Height="25" SelectionChanged="PreviewSettings_Changed">
                        <ComboBoxItem Content="Color" IsSelected="True"/>
                        <ComboBoxItem Content="Grayscale"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Orientation:" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="OrientationComboBox" Height="25" SelectionChanged="PreviewSettings_Changed">
                        <ComboBoxItem Content="Auto" IsSelected="True"/>
                        <ComboBoxItem Content="Portrait"/>
                        <ComboBoxItem Content="Landscape"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Paper Size / Fit Mode / Watermark -->
            <Grid Grid.Row="5" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Paper Size:" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="PaperSizeComboBox" Height="25" SelectionChanged="PreviewSettings_Changed">
                        <ComboBoxItem Content="Auto (Match Document)" IsSelected="True"/>
                        <ComboBoxItem Content="A3"/>
                        <ComboBoxItem Content="A4"/>
                        <ComboBoxItem Content="Letter"/>
                        <ComboBoxItem Content="Legal"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Fit Mode:" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="FitModeComboBox" Height="25" SelectionChanged="PreviewSettings_Changed">
                        <ComboBoxItem Content="Fit to Page"   Tag="FitToPage"   IsSelected="True"/>
                        <ComboBoxItem Content="Shrink to Fit" Tag="ShrinkToFit"/>
                        <ComboBoxItem Content="Actual Size"   Tag="ActualSize"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Watermark (Optional):" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="WatermarkTextBox" Height="25" VerticalContentAlignment="Center" TextChanged="WatermarkTextBox_TextChanged"/>
                </StackPanel>
            </Grid>

            <!-- Page Range -->
            <StackPanel Grid.Row="6" Margin="0,0,0,16">
                <TextBlock Text="Pages to Print (e.g. 1-5, 8) — Leave empty for all:" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox x:Name="PageRangeTextBox" Height="25" VerticalContentAlignment="Center"
                         TextChanged="PageRangeTextBox_TextChanged"/>
            </StackPanel>

            <!-- Action Buttons -->
            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="HistoryBtn" Content="View History" Grid.Column="0" Height="35" Padding="15,0" Click="HistoryBtn_Click"/>
                <Button x:Name="MergeBtn" Content="Merge PDFs" Grid.Column="2" Height="35" Width="90" Margin="0,0,10,0" Background="#28A745" Foreground="White" FontWeight="Bold" Click="MergeBtn_Click"/>
                <Button x:Name="CancelBtn" Content="Cancel" Grid.Column="3" Height="35" Width="80" Margin="0,0,10,0" Click="CancelButton_Click"/>
                <Button x:Name="PrintBtn" Content="Print" Grid.Column="4" Height="35" Width="100" Background="#0078D7" Foreground="White" FontWeight="Bold" Click="PrintButton_Click"/>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════ SPLITTER ═══════════════════════════════════ -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0" Cursor="SizeWE"/>

        <!-- ═══════════════════════════════════ RIGHT: Inline Preview ═══════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Toolbar -->
                <RowDefinition Height="*"/>    <!-- Image -->
                <RowDefinition Height="Auto"/> <!-- File label -->
            </Grid.RowDefinitions>

            <!-- Preview toolbar -->
            <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Margin="8,5">
                    <Button x:Name="InlinePrevBtn" Content="◀" Width="28" Height="26" Padding="0"
                            Click="InlinePrevBtn_Click" IsEnabled="False" FontSize="10"/>
                    <TextBlock x:Name="InlinePageLabel" Text="Select a file to preview"
                               VerticalAlignment="Center" Margin="8,0" FontSize="11" Foreground="#444"/>
                    <Button x:Name="InlineNextBtn" Content="▶" Width="28" Height="26" Padding="0"
                            Click="InlineNextBtn_Click" IsEnabled="False" FontSize="10"/>
                    <Button x:Name="PopOutBtn" Content="⤢ Open Viewer" Height="26" Padding="8,0" Margin="10,0,0,0"
                            FontSize="10" Click="PopOutBtn_Click" IsEnabled="False" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Preview image -->
            <Grid Grid.Row="1">
                <ScrollViewer x:Name="InlineScrollViewer"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Background="#525659"
                              SizeChanged="InlineScrollViewer_SizeChanged">
                    <Border x:Name="InlinePageBorder" Background="White" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Margin="20">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="8" Opacity="0.6"/>
                        </Border.Effect>
                        <Image x:Name="InlinePreviewImage"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="None"/>
                    </Border>
                </ScrollViewer>
                
                <TextBlock x:Name="PaperInfoLabel" Text="" Foreground="#E0E0E0" 
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0" 
                           FontSize="11" IsHitTestVisible="False"/>
            </Grid>

            <!-- File name -->
            <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
                <TextBlock x:Name="InlineFileLabel" Text="" Margin="8,4"
                           FontSize="10" Foreground="#666" TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>
    </Grid>
</Window>
