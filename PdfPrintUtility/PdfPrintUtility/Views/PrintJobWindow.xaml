<Window x:Class="PdfPrintUtility.Views.PrintJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Print Job" Height="450" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock x:Name="SummaryTextBlock" Text="Ready to print X selected PDFs." FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
        
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Printer:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="PrinterComboBox" Height="25"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Copies:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="CopiesTextBox" Height="25" Text="1" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <CheckBox x:Name="DuplexCheckBox" Content="Double-Sided (Duplex)" Margin="0,0,20,0"/>
            <CheckBox x:Name="CollateCheckBox" Content="Collate Copies" IsChecked="True"/>
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Color Mode:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ColorComboBox" Height="25">
                    <ComboBoxItem Content="Color" IsSelected="True"/>
                    <ComboBoxItem Content="Grayscale"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Orientation:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="OrientationComboBox" Height="25">
                    <ComboBoxItem Content="Auto" IsSelected="True"/>
                    <ComboBoxItem Content="Portrait"/>
                    <ComboBoxItem Content="Landscape"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock Text="Paper Size:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="PaperSizeComboBox" Height="25">
                <ComboBoxItem Content="A3"/>
                <ComboBoxItem Content="A4" IsSelected="True"/>
                <ComboBoxItem Content="Letter"/>
                <ComboBoxItem Content="Legal"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal">
            <Button x:Name="RegisterButton" Content="Register Context Menu" Padding="10,5" Margin="0,0,10,0" Click="RegisterButton_Click"/>
            <Button x:Name="UnregisterButton" Content="Unregister Context Menu" Padding="10,5" Click="UnregisterButton_Click"/>
        </StackPanel>

        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="CancelBtn" Content="Cancel" Grid.Column="0" Height="35" Margin="0,0,5,0" Click="CancelButton_Click"/>
            <Button x:Name="PrintBtn" Content="Print" Grid.Column="1" Height="35" Margin="5,0,0,0" Background="#0078D7" Foreground="White" FontWeight="Bold" Click="PrintButton_Click"/>
        </Grid>
    </Grid>
</Window>
